{
  "_comment": "OpenTalon LLM 配置文件",
  "_docs": "复制此文件并修改配置，或设置环境变量",
  
  "provider": "openai",
  "api_key": "YOUR_API_KEY_HERE",
  "base_url": "https://api.openai.com/v1",
  "model": "gpt-3.5-turbo",
  
  "_alternatives": {
    "ollama": {
      "provider": "ollama",
      "base_url": "http://localhost:11434",
      "model": "llama2"
    },
    "lmstudio": {
      "provider": "lmstudio",
      "base_url": "http://localhost:1234/v1",
      "model": "local-model"
    }
  },
  
  "timeout": 60,
  "max_tokens": 4096,
  "temperature": 0.7
}
